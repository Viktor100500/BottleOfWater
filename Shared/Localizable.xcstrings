    "Don't drink a lot right before bed — better an hour earlier." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trink nicht viel direkt vor dem Schlafen — besser eine Stunde vorher."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No bebas mucho justo antes de dormir; mejor una hora antes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Évitez de beaucoup boire juste avant de dormir — plutôt une heure avant."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non bere molto subito prima di dormire: meglio un'ora prima."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "寝る直前の飲みすぎは避けて、1時間前までに。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자기 직전 말고 한 시간 전에 마시는 게 좋아요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não beba muito na hora de dormir — melhor uma hora antes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не пейте много прямо перед сном — лучше за час до него."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yatmadan hemen önce çok içme — bir saat öncesi daha iyi."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "睡前别大量喝水，最好提前一小时。"
          }
        }
      }
    },
