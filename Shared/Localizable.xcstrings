    "Add the Bottle of Water widget to your Home Screen or Lock Screen. Widget buttons log water without opening the app." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Füge das Bottle-of-Water-Widget zum Start- oder Sperrbildschirm hinzu. Die Buttons protokollieren Wasser, ohne die App zu öffnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade el widget de Bottle of Water a la pantalla de inicio o de bloqueo. Sus botones registran agua sin abrir la app."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez le widget Bottle of Water à l'écran d'accueil ou de verrouillage. Ses boutons enregistrent l'eau sans ouvrir l'app."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi il widget di Bottle of Water alla schermata Home o di blocco. I pulsanti registrano l'acqua senza aprire l'app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
