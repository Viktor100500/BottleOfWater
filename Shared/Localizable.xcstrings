    "Coffee and tea count too, but plain water works best." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaffee und Tee zählen auch, aber Wasser wirkt am besten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El café y el té también cuentan, pero el agua es lo que mejor funciona."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le café et le thé comptent aussi, mais l'eau reste la meilleure."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anche caffè e tè contano, ma l'acqua funziona meglio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コーヒーや紅茶も水分ですが、水が一番です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "커피와 차도 수분이지만 물이 가장 좋아요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Café e chá também contam, mas água pura funciona melhor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кофе и чай тоже жидкость, но вода работает лучше всего."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kahve ve çay da sayılır ama en iyisi sudur."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "咖啡和茶也算，但白水效果最好。"
          }
        }
      }
    },
    "Cool water is absorbed faster than warm water." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
